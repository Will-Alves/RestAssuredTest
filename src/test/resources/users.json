{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id":     { "type": "integer" },
      "name":   { "type": "string"  },
      "age":    { "type": "integer" },
      "salary": { "type": ["number", "null"] }
    },
    "required": ["id", "name", "age"]
  }
}
